# EC2 / Docker Compose용 — 서버에 `.env`로 복사 후 값 채우기
# docker-compose.yml이 POSTGRES_PASSWORD로 DB 비밀번호를 주입합니다.

NODE_ENV=production
PORT=3000

# Compose가 postgres 컨테이너와 DATABASE_URL 생성에 사용 (필수)
POSTGRES_PASSWORD=change-this-strong-password

# 앱 컨테이너는 compose가 아래를 덮어씁니다 (로컬 npm 개발용 값과 달라도 됨)
# DATABASE_URL=
# REDIS_URL=

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

EMAIL_FROM=noreply@example.com

# OTP 메일: AWS SES 또는 SMTP (Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true, SMTP_USER/PASS 앱비밀번호)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# 프론트 배포 URL (HTTPS 권장). 여러 개면 쉼표로 구분.
# CORS_ORIGIN=https://app.example.com

# EC2에서 API 컨테이너까지 한 번에 띄우려면:
# COMPOSE_PROFILES=api
