      "contentText": {
        "title": "이에요/예요",
        "explanations": [
          {
            "lang": "en",
            "text": "A noun marker used like 'Be' Verb, to tell that a noun IS something."
          },
          {
            "lang": "he",
            "text": "סימון שם עצם שמשתמשים בו כאשר רוצים לתאר ששם העצם הוא משהו."
          }
        ],
        "imageUrl": "",
        "dialogues": [
          {
            "lines": [
              { "speaker": "가", "ko": "미국 사람이에요?", "en": "Are you american?", "he": "את/ה אמריקאי/ת?" },
              { "speaker": "나", "ko": "네, 미국 사람이에요.", "en": "Yes, I'm american.", "he": "כן, אני אמריקאי/ת." }
            ]
          },
          {
            "lines": [
              { "speaker": "가", "ko": "가수예요?", "en": "Are you a singer?", "he": "את/ה זמר/ת?" },
              { "speaker": "나", "ko": "네, 가수예요.", "en": "Yes, I am a singer.", "he": "כן, אני זמר/ת." }
            ]
          }
        ]
      }
    },
    {
      "sequence": 2,
      "type": "GRAMMAR_TABLE",
      "isExtra": false,
      "contentText": {
        "title": "은/는",
        "explanations": [
          {
            "lang": "en",
            "text": "A noun marker that indicates the subject of the sentence."
          },
          {
            "lang": "he",
            "text": "סימון שם עצם אשר מצרפים אותו לנושא המשפט."
          }
        ],
        "imageUrl": "",
        "dialogues": [
          {
            "lines": [
              { "speaker": "가", "ko": "선생님은 어느 나라 사람이에요?", "en": "Teacher, where are you from?", "he": "המורה, מאיפה את/ה?" },
              { "speaker": "나", "ko": "저는 한국 사람이에요.", "en": "I'm Korean.", "he": "אני קוריאני/ת." }
            ]
          }
        ]
      }
    }
  ],
