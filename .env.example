NODE_ENV=development
PORT=3000

# docker compose의 postgres와 동일한 비밀번호 (Compose 사용 시 필수)
POSTGRES_PASSWORD=dojeon_secret

DATABASE_URL=postgresql://dojeon:dojeon_secret@localhost:5432/dojeon?schema=public

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

EMAIL_FROM=noreply@example.com

# 이메일 발송: (1) AWS SES — AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY + SES에서 발신 주소 검증
# (2) SMTP(Gmail 등) — 아래 세트면 SES 없이도 발송 가능 (Gmail은 앱 비밀번호 사용)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@gmail.com
# SMTP_PASS=앱비밀번호
# EMAIL_FROM=your@gmail.com

# 브라우저 프론트 연동 시 허용할 Origin (쉼표 구분).
# development: 비우면 모든 Origin 허용. production: 반드시 설정(미설정 시 서버 기동 실패).
# 예: CORS_ORIGIN=https://app.example.com,http://localhost:5173
CORS_ORIGIN=

# production에서만 true일 때 Swagger UI(/docs) 노출. production 기본은 비활성.
SWAGGER_ENABLED=false
