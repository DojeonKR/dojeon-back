NODE_ENV=development
PORT=3000

# docker compose의 postgres와 동일한 비밀번호 (Compose 사용 시 필수)
POSTGRES_PASSWORD=dojeon_secret

DATABASE_URL=postgresql://dojeon:dojeon_secret@localhost:5432/dojeon?schema=public&connection_limit=15&pool_timeout=10

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# (선택) CloudFront 등 CDN 베이스 URL — 설정 시 presigned 응답의 fileUrl이 S3 직링크 대신 CDN 경로로 조합됩니다. 끝 슬래시 없이.
# CLOUDFRONT_BASE_URL=https://dxxxxxxxxxx.cloudfront.net

# Resend — https://resend.com (발신 도메인 DNS 검증 후 사용)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-verified-domain.com

# NLP 작업 큐 (SQS 표준 큐 URL)
NLP_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/your-nlp-queue

# 브라우저 프론트 연동 시 허용할 Origin (쉼표 구분).
# development: 비우면 모든 Origin 허용. production: 반드시 설정(미설정 시 서버 기동 실패).
# 예: CORS_ORIGIN=https://app.example.com,http://localhost:5173
CORS_ORIGIN=

# production에서만 true일 때 Swagger UI(/docs) 노출. production 기본은 비활성.
SWAGGER_ENABLED=false
